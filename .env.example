# SAYNISCH — Umgebungsvariablen
# Datei nach .env.local kopieren und Werte eintragen (NICHT committen).

# Kontaktformular-Versand per SMTP über das eigene Postfach (Alfahosting).
# Ohne SMTP_USER/SMTP_PASS wird die Anfrage nur serverseitig geloggt
# (Entwicklung) und der Erfolgs-State trotzdem gezeigt.

# Postfach-Adresse — dient zugleich als Absender (z. B. kontakt@saynisch.com)
SMTP_USER=

# Passwort des Postfachs (wie beim Alfahosting-Webmail-Login)
SMTP_PASS=

# Mailserver (Default: alfa3102.alfahosting-server.de) — nur bei Abweichung setzen
# SMTP_HOST=

# Port (Default: 465 = SSL; alternativ 587 = STARTTLS) — nur bei Abweichung setzen
# SMTP_PORT=

# Empfänger-Adresse für Anfragen (Default: kontakt@saynisch.com aus content.ts)
# CONTACT_TO=
