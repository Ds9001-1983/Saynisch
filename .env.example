# SAYNISCH — Umgebungsvariablen
# Datei nach .env.local kopieren und Werte eintragen (NICHT committen).

# Kontaktformular-Versand über Resend (EU-Region). Ohne Key wird die Anfrage
# nur serverseitig geloggt (Entwicklung) und der Erfolgs-State trotzdem gezeigt.
RESEND_API_KEY=

# Empfänger-Adresse für Anfragen (Default: kontakt@saynisch.com aus content.ts)
CONTACT_TO=

# Absender (muss eine in Resend verifizierte Domain sein)
# Beispiel: "SAYNISCH Website <anfrage@saynisch.com>"
CONTACT_FROM=
